# Slopless Command Center - Environment Variables
# Copy this to .env and fill in your values:
#   cp .env.example .env

# ── Required ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...         # Anthropic API key (console.anthropic.com)
TELEGRAM_BOT_TOKEN=123456:ABC-...    # Telegram bot token (from @BotFather)

# ── Git & GitHub ──────────────────────────────────
# GH_TOKEN=ghp_...                   # GitHub PAT (if not using `gh auth login`)
# GPG_KEY_ID=1817B6D2C1EA66AF        # GPG key ID for commit signing

# ── Slopless CLI ──────────────────────────────────
# SLOPLESS_LICENSE_KEY=sl-...        # Slopless CLI license key
# SLOPLESS_API_URL=https://api.slopless.work

# ── Integrations ─────────────────────────────────
# NOTION_TOKEN=ntn_...               # Notion integration token (notion.so/my-integrations)
# NOTION_DASHBOARD_DB=...            # Notion database ID for Life Dashboard (optional)
# CLICKUP_TOKEN=pk_...               # ClickUp API token (app.clickup.com/settings/apps)
# SLACK_TOKEN=xoxb-...               # Slack bot token (api.slack.com/apps)
# LINEAR_TOKEN=lin_api_...           # Linear API key (linear.app/settings/api)
# JIRA_TOKEN=...                     # Jira API token (id.atlassian.com/manage-profile/security/api-tokens)
# PUSHOVER_TOKEN=...                 # Pushover application token (pushover.net)
# PUSHOVER_USER_KEY=...              # Pushover user key

# ── Optional Providers ────────────────────────────
# OPENROUTER_API_KEY=sk-or-...       # If using OpenRouter instead of Anthropic
